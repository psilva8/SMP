# Enable URL rewriting
RewriteEngine On

# Set the base directory
RewriteBase /

# Redirect old neighborhood URLs to new area URLs
# Example: /neighborhoods/beverly-hills.html to /area/beverly-hills/
RewriteRule ^neighborhoods/([^/]+)\.html$ /area/$1/ [R=301,L]

# Handle areas without trailing slash
# Example: /area/beverly-hills to /area/beverly-hills/
RewriteRule ^area/([^/]+)$ /area/$1/ [R=301,L]

# Handle URLs without index.html
# Example: /area/beverly-hills/ to /area/beverly-hills/index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^area/([^/]+)/$ area/$1/index.html [L]

# Preserve query parameters
RewriteCond %{QUERY_STRING} ^area=([^&]+)$
RewriteRule ^neighborhoods\.html$ /area/%1/? [R=301,L]

# Redirect neighborhood.html?area=xyz to area/xyz/
RewriteCond %{QUERY_STRING} ^area=([^&]+)$
RewriteRule ^neighborhoods\.html$ /area/%1/? [R=301,L]

# Redirect old areas URLs to new area URLs
RewriteRule ^areas/([^/]+)/$ /area/$1/ [R=301,L]
RewriteRule ^areas/([^/]+)$ /area/$1/ [R=301,L]

# Remove trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Handle neighborhoods URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^neighborhoods/([^/]+)/?$ neighborhoods/$1.html [L]

# Handle URLs without .html extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Set default index file
DirectoryIndex index.html

# Set character encoding
AddDefaultCharset UTF-8

# Set content type for JSON files
AddType application/json .json

# Prevent directory listing
Options -Indexes

# Custom error pages
ErrorDocument 404 /404.html 